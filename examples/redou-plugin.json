{
  "id": "redou-minimax-bridge",
  "name": "MiniMax Bridge",
  "version": "0.1.6",
  "description": "Expose MiniMax Token Plan MCP tools and MiniMax HTTP/WebSocket multimodal tools as one MCP server.",
  "mcp": {
    "type": "stdio",
    "command": "node",
    "args": [
      "./dist/index.js"
    ],
    "managedByAgent": true
  },
  "permissions": [
    "network",
    "file.write",
    "secret.read",
    "process.spawn"
  ],
  "secrets": [
    "MINIMAX_API_KEY",
    "MINIMAX_PLAN_API_KEY"
  ],
  "tools": [
    "web_search",
    "understand_image",
    "text_to_audio",
    "query_text_to_audio",
    "list_voices",
    "voice_clone",
    "text_to_image",
    "generate_video",
    "image_to_video",
    "query_video_generation",
    "video_template_generation",
    "query_video_template_generation",
    "lyrics_generation",
    "music_generation",
    "music_cover_preprocess"
  ],
  "manifest": "./agent.manifest.json",
  "envSchema": {
    "MINIMAX_API_KEY": {
      "type": "secret",
      "required": false,
      "description": "Configure this later in your agent/OpenRedou UI."
    },
    "MINIMAX_API_HOST": {
      "type": "string",
      "default": "https://api.minimaxi.com"
    },
    "MINIMAX_MCP_BASE_PATH": {
      "type": "path",
      "default": "./outputs/minimax"
    },
    "MINIMAX_T2A_MODE": {
      "type": "select",
      "default": "async",
      "options": [
        "async",
        "websocket"
      ]
    },
    "MINIMAX_ENABLE_TOKEN_PLAN_PROXY": {
      "type": "select",
      "default": "false",
      "options": [
        "true",
        "false"
      ]
    },
    "MINIMAX_PLAN_API_KEY": {
      "type": "secret",
      "required": false
    }
  }
}
